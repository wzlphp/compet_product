# 亚马逊竞品分析工具 - 环境变量配置

# 数据库 (默认使用SQLite)
DATABASE_URL=sqlite:///./data/compet.db

# Keepa API (推荐)
# 获取: https://keepa.com/#!api
KEEPA_API_KEY=your_keepa_api_key

# Amazon PA-API (可选)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# 爬虫配置
REQUEST_DELAY=3.0
MAX_RETRIES=3

# 监控报警阈值
PRICE_ALERT_THRESHOLD=0.05
BSR_ALERT_THRESHOLD=0.20
